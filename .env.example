# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ALLOWED_GITHUB_LOGIN=  # GitHub username allowed to sign in (leave empty to allow all)

# Upstash Redis — add via Vercel Storage > Serverless Redis, then pull with: npx vercel env pull
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Discord Application (https://discord.com/developers/applications)
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
